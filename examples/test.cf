#macro vec2(T)

typedef struct {
    T x;
    T y;
} vec2_##T ;

#endm


void my_free(void *tr) {
    free(tr);
}


vec2(int)

int main()
@{

vec2_int vec;
vec.x = 5;
vec.y = 3;

i32 * buffer = malloc(sizeof(i32));
mfcu(my_free,buffer);

{
printf(" welcome to cflat\n");
}

*buffer = 3;

return 0;
